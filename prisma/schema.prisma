generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
  extensions = [pg_trgm, uuid_ossp(map: "uuid-ossp")]
}

enum OrgPlan {
  STARTER
  GROWTH
  PRO
  ENTERPRISE
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
}

enum ContactSource {
  MANUAL
  CSV_IMPORT
  WHATSAPP
  API
  WIDGET
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  SNOOZED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  TEMPLATE
  INTERACTIVE
  LOCATION
  CONTACTS
  STICKER
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum FlowTrigger {
  KEYWORD
  NEW_CHAT
  TAG_ADDED
  MANUAL
  API
  INACTIVITY
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

enum ApiKeyScope {
  READ
  WRITE
  ADMIN
}

model Org {
  id String @id @default(uuid())
  name String
  slug String @unique
  plan OrgPlan @default(STARTER)
  credits Int @default(1000)

  // WhatsApp Config
  wabaId String? @unique
  phoneNumberId String? @unique
  wabaToken String? @db.Text
  businessId String?
  webhookUrl String?

  // Branding
  logo String?
  primaryColor String? @default("#25D366")
  domain String? @unique

  // AI Config
  aiEnabled Boolean @default(false)
  systemPrompt String? @db.Text

  // Billing
  stripeCustomerId String? @unique
  subscriptionId String? @unique
  trialEndsAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users User[]
  contacts Contact[]
  conversations Conversation[]
  flows Flow[]
  campaigns Campaign[]
  templates Template[]
  catalogs Catalog[]
  products Product[]
  orders Order[]
  apiKeys ApiKey[]
  roles Role[]
  auditLogs AuditLog[]
  webhooks Webhook[]
  flowRuns FlowRun[]

  @@index([slug])
  @@index([deletedAt])
}

model User {
  id String @id @default(uuid())
  orgId String
  email String @unique
  name String
  passwordHash String
  role UserRole @default(AGENT)
  avatar String?
  phone String?

  // Auth
  emailVerified Boolean @default(false)
  lastLoginAt DateTime?
  ssoId String? @unique

  // Permissions
  customRoleId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customRole Role? @relation(fields: [customRoleId], references: [id])
  conversations Conversation[] @relation("AssignedConversations")
  messages Message[] @relation("SentMessages")
  auditLogs AuditLog[]

  @@index([orgId])
  @@index([email])
  @@index([deletedAt])
}

model Contact {
  id String @id @default(uuid())
  orgId String
  waId String
  phone String
  name String?
  email String?
  avatar String?
  source ContactSource @default(MANUAL)

  // Data
  tags String[] @default([])
  customFields Json? @default("{}")
  notes String? @db.Text

  // Status
  blocked Boolean @default(false)
  optedOut Boolean @default(false)

  // Meta
  firstSeenAt DateTime @default(now())
  lastSeenAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  orders Order[]

  @@unique([orgId, waId])
  @@index([orgId])
  @@index([phone])
  @@index([email])
  @@index([tags])
  @@index([deletedAt])
}

model Conversation {
  id String @id @default(uuid())
  orgId String
  contactId String
  assignedToId String?

  status ConversationStatus @default(OPEN)
  priority Int @default(0)
  tags String[] @default([])

  // Meta
  lastMessageAt DateTime @default(now())
  snoozedUntil DateTime?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("AssignedConversations", fields: [assignedToId], references: [id])
  messages Message[]
  flowRuns FlowRun[]

  @@index([orgId, status])
  @@index([contactId])
  @@index([assignedToId])
  @@index([lastMessageAt])
}

model Message {
  id String @id @default(uuid())
  conversationId String
  direction MessageDirection
  type MessageType

  // Content
  text String? @db.Text
  mediaUrl String?
  mediaMimeType String?
  mediaSize Int?
  mediaCaption String? @db.Text

  // Template
  templateName String?
  templateLang String? @default("en")
  templateVars Json?

  // Interactive
  interactiveType String?
  interactiveData Json?

  // Status
  status MessageStatus @default(QUEUED)
  waMessageId String? @unique
  errorCode String?
  errorMessage String? @db.Text

  // Meta
  sentById String?
  sentAt DateTime @default(now())
  deliveredAt DateTime?
  readAt DateTime?

  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentBy User? @relation("SentMessages", fields: [sentById], references: [id])

  @@index([conversationId, sentAt])
  @@index([waMessageId])
  @@index([status])
}

model Flow {
  id String @id @default(uuid())
  orgId String
  name String
  description String? @db.Text
  trigger FlowTrigger

  // Config
  triggerConfig Json @default("{}")
  nodes Json @default("[]")
  edges Json @default("[]")

  // Status
  isActive Boolean @default(false)
  version Int @default(1)

  // Stats
  runCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
  flowRuns FlowRun[]

  @@index([orgId, isActive])
  @@index([trigger])
}

model FlowRun {
  id String @id @default(uuid())
  flowId String
  conversationId String
  orgId String

  status String @default("RUNNING")
  currentNodeId String?
  context Json @default("{}")

  startedAt DateTime @default(now())
  completedAt DateTime?
  errorMessage String? @db.Text

  flow Flow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@index([conversationId])
  @@index([status])
}

model Template {
  id String @id @default(uuid())
  orgId String
  name String
  category String
  language String @default("en")

  // Content
  header String? @db.Text
  body String @db.Text
  footer String? @db.Text
  buttons Json @default("[]")

  // Meta
  status String @default("PENDING")
  waId String? @unique
  rejectedReason String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@unique([orgId, name, language])
  @@index([orgId])
  @@index([status])
}

model Campaign {
  id String @id @default(uuid())
  orgId String
  name String
  templateId String?

  // Audience
  audienceQuery Json @default("{}")
  contactIds String[] @default([])

  // Schedule
  status CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  startedAt DateTime?
  completedAt DateTime?

  // Stats
  totalCount Int @default(0)
  sentCount Int @default(0)
  deliveredCount Int @default(0)
  readCount Int @default(0)
  failedCount Int @default(0)

  // Rate Limit
  ratePerMinute Int @default(60)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
  template Template? @relation(fields: [templateId], references: [id])

  @@index([orgId, status])
  @@index([scheduledAt])
}

model Catalog {
  id String @id @default(uuid())
  orgId String
  metaCatalogId String @unique
  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([orgId])
}

model Product {
  id String @id @default(uuid())
  catalogId String
  orgId String
  metaProductId String @unique

  name String
  description String? @db.Text
  price Int
  currency String @default("USD")
  imageUrl String?
  url String?
  availability String @default("in stock")

  // Meta
  sku String?
  category String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  catalog Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([orgId])
  @@index([catalogId])
  @@index([sku])
}

model Order {
  id String @id @default(uuid())
  orgId String
  contactId String

  // Payment
  stripeSessionId String? @unique
  stripePaymentId String? @unique
  amount Int
  currency String @default("USD")
  status OrderStatus @default(PENDING)

  // Shipping
  shippingAddress Json?

  // Meta
  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([orgId])
  @@index([contactId])
  @@index([status])
}

model OrderItem {
  id String @id @default(uuid())
  orderId String
  productId String

  quantity Int
  price Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model ApiKey {
  id String @id @default(uuid())
  orgId String
  name String
  keyHash String @unique
  keyPrefix String

  scope ApiKeyScope @default(READ)

  // Limits
  rateLimit Int @default(1000)

  // Status
  isActive Boolean @default(true)
  lastUsedAt DateTime?
  expiresAt DateTime?

  createdAt DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([keyHash])
}

model Role {
  id String @id @default(uuid())
  orgId String
  name String
  description String? @db.Text

  // Permissions
  permissions Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users User[]

  @@unique([orgId, name])
  @@index([orgId])
}

model AuditLog {
  id String @id @default(uuid())
  orgId String
  userId String?

  action String
  resource String
  resourceId String?
  details Json?

  ipAddress String?
  userAgent String? @db.Text

  createdAt DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([orgId, createdAt])
  @@index([userId])
  @@index([resource, resourceId])
}

model Webhook {
  id String @id @default(uuid())
  orgId String
  url String
  events String[] @default([])
  secret String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}